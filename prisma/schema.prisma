// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// Profile Service - User Identity & Authentication
// Domain: User management, authentication, basic roles, platform administration

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["profiles", "roles", "platform"]
}

// ============================================================================
// USERS & PROFILES
// ============================================================================

model User {
  user_id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_slug           String?
  first_name          String?     @default("") @db.VarChar(50)
  last_name           String?     @default("") @db.VarChar(50)
  password            String?     @default("")
  date_of_birth       DateTime    @default(now())
  email               String      @unique @db.VarChar(255)
  phone_number        String?     @unique @db.VarChar(20)
  backup_phone_number String?     @unique @db.VarChar(20)
  email_verified      Boolean?    @default(false)
  phone_verified      Boolean?    @default(false)
  kyc_verified        Boolean?    @default(false)
  is_blocked          Boolean?    @default(false)
  fcm_token           String      @default("")
  country_code        String      @default("")
  // Removed refresh_token field; now tracked in UserSession
  last_seen           String      @default("online")
  account_type        AccountType @default(INDIVIDUAL)
  permission_level    Int         @default(1)
  created_at          DateTime    @default(now())
  last_login          DateTime    @default(now())
  updated_at          DateTime    @updatedAt
  deleted_at          DateTime?   @db.Timestamptz(6)

  // Local relationships
  user_roles              UserRole[]
  business_users          BusinessUser[]
  permission_restrictions UserPermissionRestriction[]
  restricted_permissions  UserPermissionRestriction[] @relation("restricted_by")
  verifications           Verification[]
  staff                   Staff[]
  sessions                UserSession[]
  staff_invitations       StaffInvitation[]

  @@index([user_id], map: "idx_users_user_id")
  @@index([email], map: "idx_users_email")
  @@index([phone_number], map: "idx_users_phone_number")
  @@index([last_login], map: "idx_users_last_login")
  @@map("users")
  @@schema("profiles")
}

enum SessionSource {
  WEB
  MOBILE
  TABLET
  OTHER

  @@schema("profiles")
}

model UserSession {
  session_id    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String        @db.Uuid
  refresh_token String        @db.Text
  source        SessionSource @default(WEB)
  device_info   String        @db.Text // e.g., browser, device, IP, etc.
  is_active     Boolean       @default(true)
  login_at      DateTime      @default(now())

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([user_id, source], name: "unique_session")
  @@index([user_id])
  @@index([is_active])
  @@map("user_sessions")
  @@schema("profiles")
}

model BusinessUser {
  business_user_id String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String             @db.Uuid
  email            String             @unique @db.VarChar(255)
  phone_number     String?            @unique @db.VarChar(20)
  organization_id  String             @db.Uuid // Reference to Organization Service
  access_type      BusinessAccessType @default(CREATOR)
  access_level     Int                @default(1)
  is_active        Boolean            @default(true)
  notes            String?            @db.Text
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt
  deleted_at       DateTime?          @db.Timestamptz(6)

  // Relations
  user                User               @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  business_user_roles BusinessUserRole[]

  @@unique([user_id, is_active], name: "unique_active_user")
  @@unique([user_id, organization_id])
  @@index([user_id])
  @@index([organization_id])
  @@map("business_users")
  @@schema("profiles")
}

model BusinessUserRole {
  business_user_id     String    @id @db.Uuid
  organization_role_id String    @db.Uuid
  is_active            Boolean   @default(true)
  created_at           DateTime  @default(now())
  deleted_at           DateTime? @db.Timestamptz(6)

  business_user BusinessUser @relation(fields: [business_user_id], references: [business_user_id], onDelete: Cascade)

  @@map("business_user_roles")
  @@schema("roles")
}

model Staff {
  staff_id   String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id String  @db.Uuid // Reference to Organization Service
  branch_id  String? @db.Uuid // Reference to Organization Service
  user_id    String  @db.Uuid
  role_id    String? @db.Uuid // Reference to Organization Service
  email      String  @unique @db.VarChar(255)

  designation      String?
  profile_complete Boolean  @default(false)
  payroll_active   Boolean  @default(true)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relations
  user        User              @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  departments StaffDepartment[]

  @@unique([user_id, is_active])
  @@index([company_id])
  @@index([branch_id])
  @@index([user_id])
  @@map("staff")
  @@schema("profiles")
}

model StaffDepartment {
  staff_id      String    @db.Uuid
  department_id String    @db.Uuid
  is_active     Boolean   @default(true)
  deleted_at    DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  // Relations
  staff Staff @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)

  @@id([staff_id, department_id])
  @@index([staff_id])
  @@index([department_id])
  @@index([is_active])
  @@map("staff_departments")
  @@schema("profiles")
}


model StaffInvitation {
  invitation_id      String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  company_id         String           @db.Uuid // Reference to Organization Service
  branch_id          String?          @db.Uuid // Optional - for branch-specific staff
  department_id      String?          @db.Uuid // Optional - department assignment
  role_id            String?          @db.Uuid // Reference to Organization Service role
  email              String           @db.VarChar(255)
  invitation_code    String           @unique @db.VarChar(100) // Unique token
  status             InvitationStatus @default(PENDING)
  invited_by_user_id String?          @db.Uuid // staff_id of person who sent invite
  invited_by_user    User?            @relation(fields: [invited_by_user_id], references: [user_id], onDelete: Cascade)
  expires_at         DateTime // 4 hours from creation
  responsed_at       DateTime? // When status changed from PENDING
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  @@index([invitation_code])
  @@index([email])
  @@index([company_id])
  @@index([status])
  @@index([expires_at])
  @@map("staff_invitations")
  @@schema("profiles")
}

model Verification {
  verification_id String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String?             @db.Uuid
  otp_code        String              @db.VarChar(6) // 6-digit OTP
  purpose         VerificationPurpose
  expires_at      DateTime
  created_at      DateTime            @default(now())
  updated_at      DateTime            @updatedAt
  user            User?               @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@index([user_id, purpose], map: "idx_verification_user_purpose")
  @@map("verifications")
  @@schema("profiles")
}

// ============================================================================
// BASIC ROLES & PERMISSIONS
// ============================================================================

model Role {
  role_id     Int       @id @default(autoincrement())
  role_name   String?   @unique @db.VarChar(50)
  description String?   @default("")
  is_active   Boolean?  @default(true)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at  DateTime? @db.Timestamptz(6)

  user_roles UserRole[]

  @@index([role_name], map: "idx_roles_role_name")
  @@map("roles")
  @@schema("roles")
}

model UserRole {
  user_id   String  @db.Uuid
  role_name String  @default("")
  is_active Boolean @default(false)

  user User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  role Role @relation(fields: [role_name], references: [role_name], onDelete: Cascade)

  @@id([user_id, role_name])
  @@unique([user_id, is_active])
  @@map("user_roles")
  @@schema("roles")
}

model UserPermissionRestriction {
  restriction_id   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  permission_name  String    @db.VarChar(50)
  restriction_type String    @db.VarChar(50) // e.g., 'payroll', 'branch', 'page'
  is_active        Boolean   @default(true)
  reason           String?   @db.Text
  restricted_by    String    @db.Uuid
  restricted_at    DateTime  @default(now())
  expires_at       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime? @db.Timestamptz(6)

  // Relations
  user               User @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  restricted_by_user User @relation("restricted_by", fields: [restricted_by], references: [user_id])

  @@unique([user_id, permission_name, is_active])
  @@index([user_id])
  @@index([permission_name])
  @@index([restriction_type])
  @@map("user_permission_restrictions")
  @@schema("roles")
}

// ============================================================================
// ENUMS
// ============================================================================

enum BusinessAccessType {
  CREATOR
  PARTNER
  VENDOR
  CLIENT
  INVESTOR

  @@schema("profiles")
}

enum VerificationPurpose {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR_AUTH

  @@schema("profiles")
}

enum InvitationStatus {
  PENDING
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED

  @@schema("profiles")
}

enum AccountType {
  ORGANIZATION
  INDIVIDUAL

  @@schema("profiles")
}
